pipeline {
    agent any
    
    triggers {
        pollSCM('* * * * *') // Run every 1 minute
    }
    
    stages {
        stage('Build Docker Image') {
            steps {
                sh 'echo "Building Docker image..."'
                sh 'docker build -f agent/dockerfile -t laravel-jenkins-agent:${BUILD_NUMBER} .'
                sh 'docker tag laravel-jenkins-agent:${BUILD_NUMBER} laravel-jenkins-agent:latest'
            }
        }
        
        stage('Build') {
            steps {
                sh 'echo "Installing dependencies with Docker..."'
                sh '''
                docker run --rm -v ${WORKSPACE}:/var/www/html laravel-jenkins-agent:latest sh -c "
                    cp .env.example .env && \
                    echo 'Configuring database connection...' && \
                    echo 'Installing dependencies...' && \
                    composer install --no-dev --optimize-autoloader && \
                    echo 'Generating application key...' && \
                    php artisan key:generate
                "
                '''
            }
        }
        
        stage('Test') {
            steps {
                sh 'echo "Running tests..."'
                sh '''
                docker run --rm -v ${WORKSPACE}:/var/www/html laravel-jenkins-agent:latest sh -c "
                    ./vendor/bin/phpunit || true
                "
                '''
            }
        }
        
        stage('Deploy') {
            steps {
                sh 'echo "Deploying Laravel application..."'
                sh '''
                docker run --rm -v ${WORKSPACE}:/var/www/html laravel-jenkins-agent:latest sh -c "
                    ansible-playbook -i inventory/hosts.ini deploy.yml || true
                "
                '''
                sh 'echo "Deployment completed!"'
            }
        }
    }
    
    post {
        always {
            sh 'echo "Cleaning up Docker containers..."'
            sh 'docker image prune -f || true'
            cleanWs()
        }
        
        success {
            sh 'echo "Pipeline succeeded! ✅"'
        }
        
        failure {
            sh 'echo "Pipeline failed! ❌"'
        }
    }
}