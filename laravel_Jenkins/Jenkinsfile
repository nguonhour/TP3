pipeline {
    agent any
    
    triggers {
        pollSCM('* * * * *') // Run every 1 minute
    }
    
    stages {
        stage('Setup') {
            steps {
                sh 'echo "Setting up Laravel environment..."'
                sh 'cp .env.example .env'
                sh 'echo "✅ Environment file created"'
            }
        }
        
        stage('Build') {
            steps {
                sh 'echo "Build Stage - Ready for Composer"'
                sh 'ls -la .env.example'
                sh 'echo "✅ Build preparation complete"'
            }
        }
        
        stage('Test') {
            steps {
                sh 'echo "Test Stage - Ready for PHPUnit"'
                sh 'echo "✅ Test configuration ready"'
            }
        }
        
        stage('Deploy') {
            steps {
                sh 'echo "Deploy Stage - Ready for Ansible"'
                sh 'echo "✅ Deployment configuration ready"'
            }
        }
    }
    
    post {
        always {
            sh 'echo "Cleaning up workspace..."'
            cleanWs()
        }
        
        success {
            sh 'echo "Pipeline succeeded! ✅"'
            // Email notification on success
            emailext(
                subject: "✅ BUILD SUCCESS: Laravel-CI-CD-Pipeline #${BUILD_NUMBER}",
                body: """
                    Pipeline Build Successful!
                    
                    Build Details:
                    - Job: ${JOB_NAME}
                    - Build #: ${BUILD_NUMBER}
                    - Status: SUCCESS ✅
                    - Build URL: ${BUILD_URL}
                """,
                to: '${DEFAULT_RECIPIENTS}',
                recipientProviders: [developers(), requestor()]
            )
            // Telegram notification on success
            sh '''
                TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-YOUR_TELEGRAM_BOT_TOKEN}"
                TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-YOUR_CHAT_ID}"
                MESSAGE="✅ Build #${BUILD_NUMBER} SUCCESS\\nJob: ${JOB_NAME}\\nView: ${BUILD_URL}"
                curl -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
                  -d "chat_id=${TELEGRAM_CHAT_ID}" \
                  -d "text=${MESSAGE}" || true
            '''
        }
        
        failure {
            sh 'echo "Pipeline failed! ❌"'
            // Email notification on failure
            emailext(
                subject: "❌ BUILD FAILURE: Laravel-CI-CD-Pipeline #${BUILD_NUMBER}",
                body: """
                    Pipeline Build Failed!
                    
                    Build Details:
                    - Job: ${JOB_NAME}
                    - Build #: ${BUILD_NUMBER}
                    - Status: FAILURE ❌
                    - Build URL: ${BUILD_URL}
                    
                    Please check the console output for more details.
                """,
                to: '${DEFAULT_RECIPIENTS}',
                recipientProviders: [developers(), requestor()]
            )
            // Telegram notification on failure
            sh '''
                TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-YOUR_TELEGRAM_BOT_TOKEN}"
                TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-YOUR_CHAT_ID}"
                MESSAGE="❌ Build #${BUILD_NUMBER} FAILED\\nJob: ${JOB_NAME}\\nView: ${BUILD_URL}"
                curl -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
                  -d "chat_id=${TELEGRAM_CHAT_ID}" \
                  -d "text=${MESSAGE}" || true
            '''
        }
    }
}